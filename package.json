{
  "name": "prs",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:server": "nx run server:serve",
    "build:server": "npm run prisma:generate && nx run server:build",
    "start:interface": "nx run interface:serve",
    "build:interface": "npm run prisma:generate && nx run interface:build",
    "prisma:generate": "prisma generate --schema=./apps/server/prisma/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=./apps/server/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./apps/server/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} ./apps/server/prisma/seed.ts"
  },
  "private": true,
  "dependencies": {
    "@prisma/client": "^4.10.1",
    "axios": "^1.3.3",
    "http-status-codes": "^2.2.0",
    "tslib": "^2.3.0",
    "zod": "^3.20.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@nrwl/esbuild": "15.7.0",
    "@nrwl/eslint-plugin-nx": "15.7.0",
    "@nrwl/js": "15.7.0",
    "@nrwl/linter": "15.7.0",
    "@nrwl/node": "15.7.0",
    "@nrwl/workspace": "15.7.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "4.17.13",
    "@types/node": "18.11.9",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "autoprefixer": "^10.4.13",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "esbuild": "^0.17.5",
    "eslint": "~8.15.0",
    "eslint-config-next": "13.1.1",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-import": "2.26.0",
    "express": "^4.18.1",
    "nx": "15.7.0",
    "postcss": "^8.4.21",
    "prettier": "^2.6.2",
    "prisma": "^4.10.1",
    "ts-node": "10.9.1",
    "typescript": "~4.8.2"
  }
}
